# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ключ Gemini API (получить в Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модель (по умолчанию gemini-2.5-flash — бесплатная, быстрая, с поддержкой картинок)
GEMINI_MODEL=gemini-2.5-flash

# Системный промпт — характер бота (необязательно)
SYSTEM_PROMPT=Ты дружелюбный и полезный ассистент. Отвечай чётко и по делу.
